---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { isPageAvailable } from '../config/page-availability';
import story from '../../data/story.json';
import PhotoGallery from '../components/PhotoGallery.astro';
import { getPhotoManifest, getAboutUsPhotosChronological } from '../utils/photos';

const aboutPhotos = await getAboutUsPhotosChronological(getPhotoManifest());
---

{
  !isPageAvailable('gallery') ? (
    <ComingSoon
      title="About Us"
      heading="About Us"
      description="Our story and photos are coming soon."
    />
  ) : (
    <BaseLayout
      title="About Us"
      description="Caleb and Emma's story and photos."
      polaroidDecor={false}
    >
      <section class="story-gallery">
        <div class="container story-gallery__intro">
          <h1>About Us</h1>
          <p class="story-gallery__text">{story.intro}</p>
        </div>

        <div class="container">
          {
            aboutPhotos.length > 0 ? (
              <PhotoGallery photos={aboutPhotos} variant="about" />
            ) : (
              <p class="story-gallery__empty">Photos coming soon.</p>
            )
          }
        </div>
      </section>
    </BaseLayout>
  )
}

<style>
  .story-gallery {
    padding: var(--space-xl) 0 var(--space-2xl);
    background: var(--color-ivory);
  }

  .story-gallery__intro {
    max-width: var(--prose-width);
    margin: 0 auto var(--space-xl);
    text-align: center;
  }

  .story-gallery__intro h1 {
    margin-bottom: var(--space-md);
  }

  .story-gallery__text {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-warm-gray);
    text-wrap: pretty;
  }

  .story-gallery__empty {
    text-align: center;
    color: var(--color-warm-gray);
    margin: 0;
  }
</style>
