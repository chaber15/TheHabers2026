---
import BaseLayout from '../layouts/BaseLayout.astro';
import registry from '../../data/registry.json';
---

<BaseLayout title="Registry" description="Caleb and Emma's wedding registry." polaroidsPerSide={2}>
  <section class="page-hero page-hero--registry">
    <div class="container">
      <h1>Registry</h1>
    </div>
  </section>

  <section class="section section--registry">
    <div class="container registry-list">
      {
        registry.registries.map((item) => (
          <article class="card registry-card">
            <h2>{item.name}</h2>
            <p>{item.description}</p>
            <a href={item.url} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              View registry
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero--registry {
    padding-bottom: var(--space-md);
  }

  .page-hero--registry h1 {
    margin-bottom: 0;
  }

  .section--registry {
    padding-top: var(--space-md);
  }
</style>
