---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { isPageAvailable } from '../config/page-availability';
import faq from '../../data/faq.json';
---

{
  !isPageAvailable('faq') ? (
    <ComingSoon
      title="FAQ"
      heading="Frequently Asked Questions"
      description="Frequently asked questions for our wedding day are coming soon."
    />
  ) : (
<BaseLayout title="FAQ" description="Frequently asked questions about Caleb and Emma's wedding." polaroidsPerSide={3}>
  <section class="page-hero">
    <div class="container">
      <h1>Frequently Asked Questions</h1>
      <p>Practical details for our wedding day!</p>
    </div>
  </section>

  <section class="section">
    <div class="container faq-list">
      {
        faq.entries.map((entry) => (
          <details class="faq-item">
            <summary>{entry.question}</summary>
            <p set:html={entry.answer} />
          </details>
        ))
      }
    </div>
  </section>
</BaseLayout>
  )
}
