---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResponsivePhoto from '../components/ResponsivePhoto.astro';
import WeddingCountdown from '../components/WeddingCountdown.astro';
import site from '../../data/site.json';
import {
  getPhotoManifest,
  getLandingPhoto,
  getDecorPhotoPool,
  type PhotoEntry,
} from '../utils/photos';

/** Home invite-board polaroids (1936 replaces B&W 1227) */
const HOME_PANEL_IDS = ['1116', '1154', '1181', '1936', '1236', '2264'];

function pickHomePanelPhotos(pool: PhotoEntry[], ids: string[]): PhotoEntry[] {
  return ids
    .map((id) => pool.find((p) => p.filename.includes(id)))
    .filter((p): p is PhotoEntry => !!p);
}

function panelCropClass(filename: string): string | undefined {
  if (filename.includes('1936')) return 'panel-photo__img--top';
  if (filename.includes('2264')) return 'panel-photo__img--right';
  return undefined;
}

const photos = getPhotoManifest();
const landingPhoto = getLandingPhoto(photos);
const decorPool = getDecorPhotoPool(photos, landingPhoto);
const panelPhotos = pickHomePanelPhotos(decorPool, HOME_PANEL_IDS);
const panelPhotosTop = panelPhotos.slice(0, 3);
const panelPhotosBottom = panelPhotos.slice(3, 6);

const [heroName1, heroName2] = site.couple.displayName.split(/\s*&\s*/);
---

<BaseLayout polaroidDecor={false}>
  <section class="hero hero-split">
    <div class="hero-grid">
      {
        landingPhoto && (
          <div class="hero-media">
            <ResponsivePhoto
              filename={landingPhoto.filename}
              alt={landingPhoto.alt}
              preset="hero"
              width={1600}
              height={1000}
              fetchpriority="high"
            />
          </div>
        )
      }

      <div class="hero-panel">
        <div class="panel-board">
          {
            panelPhotosTop.length > 0 && (
              <div class="panel-strip" aria-hidden="true">
                {
                  panelPhotosTop.map((photo, index) => (
                    <figure class:list={['panel-photo', `panel-photo--${index + 1}`]}>
                      <ResponsivePhoto
                        filename={photo.filename}
                        alt=""
                        preset="thumb"
                        loading="lazy"
                        width={280}
                        height={350}
                        class:list={[panelCropClass(photo.filename)]}
                      />
                    </figure>
                  ))
                }
              </div>
            )
          }

          <div class="panel-invite">
            <h1 class="hero-title" aria-label={site.couple.displayName}>
              <span class="hero-title__name">{heroName1}</span>
              <span class="hero-title__amp" aria-hidden="true">&</span>
              <span class="hero-title__name">{heroName2}</span>
            </h1>

            <div class="panel-details">
              <p class="hero-date">
                <span class="hero-date__day">{site.wedding.dayOfWeek},</span>{' '}
                <span class="hero-date__when">{site.wedding.formattedDate}</span>
              </p>
            </div>

            <div class="panel-meta">
              <div class="panel-venue-block">
                <p class="hero-venue">{site.venue.name}</p>
                <div class="divider panel-divider"></div>
              </div>
              <WeddingCountdown weddingDate={site.wedding.date} variant="compact" />
            </div>

            <div class="btn-group hero-actions">
              <a href="/rsvp" class="btn btn-primary">RSVP</a>
              <a href="/registry" class="btn btn-secondary">Registry</a>
            </div>
          </div>

          {
            panelPhotosBottom.length > 0 && (
              <div class="panel-strip" aria-hidden="true">
                {
                  panelPhotosBottom.map((photo, index) => (
                    <figure class:list={['panel-photo', `panel-photo--${index + 4}`]}>
                      <ResponsivePhoto
                        filename={photo.filename}
                        alt=""
                        preset="thumb"
                        loading="lazy"
                        width={280}
                        height={350}
                        class:list={[panelCropClass(photo.filename)]}
                      />
                    </figure>
                  ))
                }
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt welcome">
    <div class="container prose">
      <h2 class="section-title">We're getting married!</h2>
      <blockquote class="blockquote">
        <p>
          But from the beginning of creation, God made them male and female. Therefore a man
          shall leave his father and mother and hold fast to his wife, and the two shall become
          one flesh. So they are no longer two but one flesh. What therefore God has joined
          together, let not man separate.
        </p>
        <cite>Mark 10:6-9</cite>
      </blockquote>
    </div>
  </section>
</BaseLayout>

<style>
  /* Split hero: fits below nav without scrolling on desktop */
  .hero-split {
    background: var(--color-ivory);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .hero-media {
    position: relative;
    min-height: 48vh;
    overflow: hidden;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    min-height: 48vh;
    object-fit: cover;
    /* Pin the photo’s right edge to the panel split (meets the text column) */
    object-position: right 35%;
  }

  .hero-panel {
    display: flex;
    align-items: stretch;
    justify-content: center;
    padding: var(--space-md);
    background: var(--color-ivory-deep);
  }

  /* Photo strips + invite card */
  .panel-board {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-md);
    width: 100%;
    max-width: 26rem;
  }

  .panel-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    min-height: 0;
  }

  .panel-photo {
    margin: 0;
    padding: 4px 4px 12px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    box-shadow: 0 4px 14px rgba(42, 40, 38, 0.1);
    overflow: hidden;
  }

  .panel-photo--1 {
    transform: rotate(-4deg);
  }

  .panel-photo--2 {
    transform: rotate(2deg) translateY(4px);
  }

  .panel-photo--3 {
    transform: rotate(-2deg);
  }

  .panel-photo--4 {
    transform: rotate(3deg);
  }

  .panel-photo--5 {
    transform: rotate(-3deg) translateY(-4px);
  }

  .panel-photo--6 {
    transform: rotate(2deg);
  }

  .panel-photo img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center center;
  }

  .panel-photo__img--top {
    object-position: top center;
  }

  .panel-photo__img--right {
    object-position: right center;
  }

  .panel-invite {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(42, 40, 38, 0.08);
  }

  .hero-title {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: baseline;
    justify-content: center;
    width: 100%;
    margin: var(--space-md) 0 var(--space-md);
    font-size: clamp(2rem, 7vw, 2.85rem);
    line-height: 1.08;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .hero-title__name {
    display: inline;
  }

  .hero-title__amp {
    display: inline;
    font-size: 0.52em;
    margin: 0 0.14em;
    color: var(--color-warm-gray);
    letter-spacing: 0.1em;
    vertical-align: baseline;
  }

  .panel-details {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    width: 100%;
  }

  .hero-date {
    margin: 0;
    text-align: center;
    font-family: var(--font-detail);
    font-size: clamp(1.35rem, 2.9vw, 1.65rem);
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-charcoal);
    letter-spacing: 0.03em;
    text-wrap: balance;
  }

  .hero-date__day,
  .hero-date__when {
    display: inline;
    font-family: var(--font-detail);
  }

  .hero-date__day {
    font-size: 0.92em;
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.05em;
    color: var(--color-charcoal);
  }

  .hero-date__when {
    font-style: italic;
    color: var(--color-charcoal);
  }

  .panel-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
  }

  .panel-venue-block {
    display: grid;
    justify-items: center;
    gap: var(--space-md);
    width: fit-content;
    max-width: 16rem;
  }

  .panel-divider {
    width: 100%;
    margin: 0;
    justify-self: stretch;
  }

  .panel-meta :global(.wedding-countdown--compact) {
    margin: 0;
  }

  .panel-meta :global(.wedding-countdown--compact .countdown-value) {
    font-size: clamp(0.95rem, 1.9vw, 1.1rem);
  }

  .hero-venue {
    margin: 0;
    font-size: clamp(1.14rem, 2.4vw, 1.32rem);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-warm-gray);
    text-align: center;
    text-wrap: balance;
  }

  .hero-actions {
    margin-top: var(--space-md);
    justify-content: center;
    width: 100%;
  }

  .hero-actions .btn {
    flex: 1;
    min-width: 0;
    max-width: 9rem;
  }

  .hero-actions .btn-primary {
    box-shadow: 0 4px 16px rgba(42, 40, 38, 0.12);
  }

  @media (min-width: 640px) {
    .hero-panel {
      padding: var(--space-lg);
    }

    .panel-board {
      max-width: 28rem;
      gap: var(--space-lg);
    }

    .panel-strip {
      gap: var(--space-md);
    }

    .panel-invite {
      padding: var(--space-lg) var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero-split {
      height: calc(100dvh - var(--nav-height));
      max-height: calc(100dvh - var(--nav-height));
      overflow: hidden;
    }

    .hero-grid {
      grid-template-columns: 1.12fr 1fr;
      height: 100%;
      min-height: 0;
    }

    .hero-media {
      height: 100%;
      min-height: 0;
    }

    .hero-media img {
      min-height: 0;
      height: 100%;
      object-position: right 35%;
    }

    .hero-panel {
      height: 100%;
      min-height: 0;
      padding: var(--space-md) var(--space-md);
      border-left: 1px solid var(--color-border);
      overflow: hidden;
    }

    .panel-board {
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto minmax(0, 1fr);
      align-content: center;
      height: 100%;
      max-width: min(32rem, 100%);
      gap: var(--space-sm);
    }

    .panel-strip {
      align-content: center;
      gap: var(--space-xs);
    }

    .panel-photo {
      padding: 4px 4px 10px;
      max-height: 100%;
    }

    .panel-photo img {
      aspect-ratio: 4 / 5;
      width: 100%;
      height: auto;
      max-height: min(17vh, 168px);
      object-fit: cover;
    }

    .panel-invite {
      padding: var(--space-md) var(--space-lg);
    }

    .panel-invite .hero-title {
      margin: var(--space-lg) 0 var(--space-lg);
      font-size: clamp(2.35rem, 5.2vh, 3.85rem);
      letter-spacing: 0.05em;
    }

    .hero-date {
      font-size: clamp(1.2rem, 2.1vh, 1.45rem);
    }

    .hero-venue {
      font-size: clamp(1.1rem, 1.95vh, 1.3rem);
    }

    .panel-meta :global(.wedding-countdown--compact .countdown-value) {
      font-size: clamp(0.92rem, 1.65vh, 1.05rem);
    }

    .hero-actions {
      margin-top: var(--space-sm);
    }

    .hero-actions .btn {
      max-width: 9.5rem;
      padding-top: 0.65rem;
      padding-bottom: 0.65rem;
    }

  }

  @media (min-width: 1024px) and (max-height: 780px) {
    .panel-photo img {
      max-height: min(12vh, 118px);
    }

    .panel-invite {
      padding: var(--space-sm) var(--space-md);
    }

    .panel-invite .hero-title {
      margin: var(--space-md) 0 var(--space-md);
      font-size: clamp(2rem, 4.5vh, 3rem);
    }
  }

  .welcome .section-title {
    margin-bottom: var(--space-lg);
  }
</style>
