---
import BaseLayout from '../layouts/BaseLayout.astro';
import RsvpForm from '../components/RsvpForm.astro';
---

<BaseLayout title="RSVP" description="RSVP for Caleb and Emma's wedding." polaroidsPerSide={2}>
  <section class="page-hero">
    <div class="container">
      <h1>RSVP</h1>
      <p>Please respond by August 3rd, 2026</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <RsvpForm />
      <p class="rsvp-help">
        Having trouble? Email us at
        <a href="mailto:thehabers2026@gmail.com">thehabers2026@gmail.com</a>
        and we&rsquo;ll help.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .rsvp-help {
    max-width: 460px;
    margin: var(--space-lg) auto 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-warm-gray);
    font-style: italic;
  }

  .rsvp-help a {
    color: var(--color-sage-dark);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-sage) 50%, transparent);
    text-underline-offset: 3px;
    font-style: normal;
  }

  .rsvp-help a:hover {
    color: var(--color-sage);
    text-decoration-color: var(--color-sage);
  }
</style>
