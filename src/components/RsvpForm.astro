---
---

<div id="rsvp-form-root" class="rsvp-container"></div>

<script>
  import { initRsvpForm } from './rsvp-form.js';

  const root = document.getElementById('rsvp-form-root');
  if (root) initRsvpForm(root);
</script>

<!-- is:global — guest rows are injected via JS, so Astro scoped CSS would not apply -->
<style is:global>
  #rsvp-form-root.rsvp-container {
    max-width: 560px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  #rsvp-form-root .rsvp-intro,
  #rsvp-form-root .rsvp-greeting {
    color: var(--color-warm-gray);
    margin-bottom: var(--space-md);
  }

  #rsvp-form-root .rsvp-greeting {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--color-charcoal);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  #rsvp-form-root .radio-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  #rsvp-form-root .radio-group label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 400;
    cursor: pointer;
  }

  #rsvp-form-root .rsvp-confirmation {
    text-align: center;
  }

  #rsvp-form-root .rsvp-confirmation h2 {
    color: var(--color-sage-dark);
  }

  #rsvp-form-root .guest-list-label {
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: var(--space-md);
    color: var(--color-warm-gray);
    text-align: center;
  }

  #rsvp-form-root .guest-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  #rsvp-form-root .guest-card {
    background: var(--color-ivory);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    transition: box-shadow 0.2s ease;
  }

  #rsvp-form-root .guest-card:focus-within {
    box-shadow: 0 2px 14px var(--color-shadow);
    border-color: color-mix(in srgb, var(--color-sage) 35%, var(--color-border));
  }

  #rsvp-form-root .guest-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  #rsvp-form-root .guest-name {
    font-family: var(--font-detail);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-charcoal);
    line-height: 1.3;
  }

  #rsvp-form-root .guest-badge {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-sage-dark);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  #rsvp-form-root .guest-choices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xs);
  }

  #rsvp-form-root .guest-choice {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: var(--space-sm) var(--space-xs);
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-border);
    background: var(--color-white);
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.15s ease;
    user-select: none;
  }

  #rsvp-form-root .guest-choice:hover {
    border-color: color-mix(in srgb, var(--color-sage) 50%, var(--color-border));
  }

  #rsvp-form-root .guest-choice input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  #rsvp-form-root .guest-choice-text {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-warm-gray);
    text-align: center;
    line-height: 1.25;
  }

  #rsvp-form-root .guest-choice--yes:has(input:checked) {
    background: var(--color-sage);
    border-color: var(--color-sage);
    transform: translateY(-1px);
    box-shadow: 0 3px 10px color-mix(in srgb, var(--color-sage) 35%, transparent);
  }

  #rsvp-form-root .guest-choice--yes:has(input:checked) .guest-choice-text {
    color: var(--color-white);
  }

  #rsvp-form-root .guest-choice--no:has(input:checked) {
    background: var(--color-ivory-deep);
    border-color: var(--color-warm-gray);
  }

  #rsvp-form-root .guest-choice--no:has(input:checked) .guest-choice-text {
    color: var(--color-charcoal);
  }

  #rsvp-form-root .guest-choice:has(input:focus-visible) {
    outline: 2px solid var(--color-sage);
    outline-offset: 2px;
  }

  #rsvp-form-root .already-guest-list {
    list-style: none;
    margin: var(--space-md) auto 0;
    padding: 0;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  #rsvp-form-root .already-guest-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-ivory);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
  }

  #rsvp-form-root .already-guest-name {
    font-family: var(--font-detail);
    color: var(--color-charcoal);
  }

  #rsvp-form-root .already-guest-status {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  #rsvp-form-root .already-guest-status.is-attending {
    color: var(--color-sage-dark);
    background: color-mix(in srgb, var(--color-sage) 18%, var(--color-white));
  }

  #rsvp-form-root .already-guest-status.is-declined {
    color: var(--color-warm-gray);
    background: var(--color-white);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 400px) {
    #rsvp-form-root .guest-choices {
      grid-template-columns: 1fr;
    }

    #rsvp-form-root .guest-card-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
