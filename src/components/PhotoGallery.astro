---
import ResponsivePhoto from './ResponsivePhoto.astro';
import { sourceImageDimensions, type PhotoEntry } from '../utils/photos';

interface Props {
  photos: PhotoEntry[];
  /** `about` — masonry layout, mixed orientations, no face crop */
  variant?: 'default' | 'about';
}

const { photos, variant = 'default' } = Astro.props;

type GalleryPhoto = PhotoEntry & {
  orientation: 'landscape' | 'portrait' | 'square';
  width?: number;
  height?: number;
};

function orientationFor(
  dims: { width: number; height: number } | null
): GalleryPhoto['orientation'] {
  if (!dims) return 'portrait';
  const ratio = dims.width / dims.height;
  if (ratio > 1.15) return 'landscape';
  if (ratio < 0.85) return 'portrait';
  return 'square';
}

function enrichGalleryPhoto(photo: PhotoEntry): GalleryPhoto {
  const dims = sourceImageDimensions(photo.filename);
  return {
    ...photo,
    orientation: orientationFor(dims),
    width: dims?.width,
    height: dims?.height,
  };
}

const galleryPhotos: GalleryPhoto[] =
  variant === 'about'
    ? photos.map(enrichGalleryPhoto)
    : photos.map((photo) => ({ ...photo, orientation: 'portrait' as const }));
---

<div
  class:list={[
    'photo-gallery',
    variant === 'about' && 'photo-gallery--about',
  ]}
>
  {
    galleryPhotos.map((photo) => (
      <figure
        class:list={[
          'gallery-item',
          variant === 'about' && `gallery-item--${photo.orientation}`,
        ]}
      >
        <ResponsivePhoto
          filename={photo.filename}
          alt={photo.alt}
          preset="gallery"
          orientation={variant === 'about' ? photo.orientation : undefined}
          loading="lazy"
          width={photo.width}
          height={photo.height}
        />
      </figure>
    ))
  }
</div>

<style>
  .photo-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .gallery-item {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-white);
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }

  @media (hover: hover) {
    .gallery-item:hover img {
      transform: scale(1.02);
    }
  }

  @media (min-width: 768px) {
    .photo-gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    .photo-gallery:not(.photo-gallery--about) .gallery-item:first-child {
      grid-column: span 2;
    }

    .photo-gallery:not(.photo-gallery--about) .gallery-item:first-child img {
      aspect-ratio: 21 / 9;
    }
  }

  /* About Us — mixed-orientation masonry grid */
  .photo-gallery--about {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: start;
    grid-auto-flow: dense;
  }

  .photo-gallery--about .gallery-item {
    background: var(--color-ivory-deep);
  }

  .photo-gallery--about .gallery-item img {
    width: 100%;
    height: auto;
    aspect-ratio: unset;
    object-fit: contain;
    object-position: center center;
    vertical-align: middle;
  }

  /* Landscape shots fill their grid span and crop vertically */
  .photo-gallery--about .gallery-item--landscape img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (hover: hover) {
    .photo-gallery--about .gallery-item:hover img {
      transform: none;
    }
  }

  @media (min-width: 640px) {
    .photo-gallery--about {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-lg);
    }

    .photo-gallery--about .gallery-item--landscape {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .photo-gallery--about {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    /* 3-col grid: landscape spans 2 of 3; portrait/square use 1 */
    .photo-gallery--about .gallery-item--landscape {
      grid-column: span 2;
    }

    .photo-gallery--about .gallery-item--portrait,
    .photo-gallery--about .gallery-item--square {
      grid-column: span 1;
    }
  }
</style>
